                <mxCell id="a-validation" value="&lt;b&gt;productDataValidation()&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:10px;color:#555&#39;&gt;Valida: nome e categoria obrigatorios, preco valido&lt;br/&gt;(numero maior que zero), PDF e ao menos 1 imagem.&lt;br/&gt;Lanca erro imediatamente se algo estiver errado.&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="bg-a" vertex="1">
