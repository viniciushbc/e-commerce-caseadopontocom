                <mxCell id="bg-a" value="FLUXO DO ADMIN" style="swimlane;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;align=left;spacingLeft=10;" parent="1" vertex="1">
