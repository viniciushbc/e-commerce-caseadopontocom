                <mxCell id="e-a2" style="edgeStyle=orthogonalEdgeStyle;html=1;" parent="bg-a" source="a-r-admin" target="a-auth-get" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e-a3" value="200 OK — credenciais corretas" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=9;fontColor=#555;strokeColor=#82b366;" parent="bg-a" source="a-auth-get" target="a-admin-html" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint y="-14" as="offset"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="e-a4" value="401/403 — acesso negado" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;fontSize=9;fontColor=#b85450;" parent="bg-a" source="a-auth-get" target="a-browser" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint y="-35" as="offset"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="a-lbl2" value="PASSO 2 — Agora na pagina admin, preenche o formulario e envia para criar o produto" style="text;html=1;fontStyle=1;fontSize=10;fillColor=#ffd966;strokeColor=#d6b656;rounded=1;align=left;spacingLeft=6;" vertex="1" parent="bg-a">
                    <mxGeometry x="10" y="222" width="680" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="a-r-create" value="&lt;b&gt;POST /api/admin/products&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:10px;color:#555&#39;&gt;Rota para criar produto.&lt;br/&gt;Recebe multipart/form-data:&lt;br/&gt;nome, categoria, descricao, preco,&lt;br/&gt;imagens[] e PDF.&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="bg-a" vertex="1">
                    <mxGeometry x="245" y="250" width="215" height="95" as="geometry"/>
                </mxCell>
                <mxCell id="a-auth-post" value="&lt;b&gt;adminAuth&lt;/b&gt;&lt;br/&gt;(Basic Auth)&lt;br/&gt;&lt;font style=&#39;font-size:10px;color:#555&#39;&gt;Verifica as credenciais novamente&lt;br/&gt;antes de processar o cadastro.&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="bg-a" vertex="1">
                    <mxGeometry x="528" y="243" width="180" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="a-multer" value="&lt;b&gt;multer&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:10px;color:#555&#39;&gt;Intercepta os arquivos enviados (imagens e PDF)&lt;br/&gt;e os deixa disponiveis em memoria&lt;br/&gt;para o servidor processar.&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="bg-a" vertex="1">
                    <mxGeometry x="790" y="252" width="215" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="e-a5" value="admin preenche e submete o formulario" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=9;fontColor=#555;" parent="bg-a" source="a-admin-html" target="a-r-create" edge="1">
