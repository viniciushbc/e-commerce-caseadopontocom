                </mxCell>
                <mxCell id="a-lbl1" value="PASSO 1 — Admin tenta acessar o painel (autenticacao obrigatoria)" style="text;html=1;fontStyle=1;fontSize=10;fillColor=#ffd966;strokeColor=#d6b656;rounded=1;align=left;spacingLeft=6;" vertex="1" parent="bg-a">
                    <mxGeometry x="10" y="40" width="500" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="a-browser" value="&lt;b&gt;Admin&lt;/b&gt;&lt;br/&gt;(Navegador)&lt;br/&gt;&lt;font style=&#39;font-size:10px;color:#555&#39;&gt;Painel de administracao,&lt;br/&gt;para cadastrar produtos.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="bg-a" vertex="1">
                    <mxGeometry x="20" y="70" width="155" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="a-r-admin" value="&lt;b&gt;GET /admin&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:10px;color:#555&#39;&gt;Rota para acessar o painel.&lt;br/&gt;Passa obrigatoriamente pelo adminAuth.&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="bg-a" vertex="1">
                    <mxGeometry x="245" y="78" width="205" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="a-auth-get" value="&lt;b&gt;adminAuth&lt;/b&gt;&lt;br/&gt;(Basic Auth)&lt;br/&gt;&lt;font style=&#39;font-size:10px;color:#555&#39;&gt;Verifica usuario e senha no header.&lt;br/&gt;Sem credenciais corretas: bloqueia.&lt;br/&gt;middlewares/adminAuth.js&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="bg-a" vertex="1">
                    <mxGeometry x="520" y="52" width="195" height="115" as="geometry"/>
                </mxCell>
                <mxCell id="a-admin-html" value="&lt;b&gt;admin.html&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:10px;color:#555&#39;&gt;Pagina do painel com formulario&lt;br/&gt;para cadastrar produto:&lt;br/&gt;nome, preco, imagens, PDF.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" parent="bg-a" vertex="1">
                    <mxGeometry x="800" y="65" width="195" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="e-a1" value="tenta acessar o painel" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=9;fontColor=#555;" parent="bg-a" source="a-browser" target="a-r-admin" edge="1">
