                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e-a7" value="autenticado, prossegue" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=9;fontColor=#555;strokeColor=#82b366;" parent="bg-a" source="a-auth-post" target="a-multer" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint y="-14" as="offset"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="a-lbl3" value="PASSO 3 — Servico orquestra a criacao: valida os dados e executa as etapas em sequencia" style="text;html=1;fontStyle=1;fontSize=10;fillColor=#ffd966;strokeColor=#d6b656;rounded=1;align=left;spacingLeft=6;" vertex="1" parent="bg-a">
                    <mxGeometry x="10" y="415" width="730" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="a-service" value="&lt;b&gt;adminCreateProduct.service.js&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:10px;color:#555&#39;&gt;Orquestra tudo: valida, salva no banco e faz uploads.&lt;br/&gt;Se qualquer etapa falhar, desfaz automaticamente.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="bg-a" vertex="1">
                    <mxGeometry x="245" y="443" width="280" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="e-a8" value="arquivos processados" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=9;fontColor=#555;" parent="bg-a" source="a-multer" target="a-service" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint y="-14" as="offset"/>
                    </mxGeometry>
